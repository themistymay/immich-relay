# ── Immich ────────────────────────────────────────────────────────────────────
IMMICH_BASE_URL=https://your-immich-instance.example.com
IMMICH_API_KEY=your_immich_api_key_here

# ── Google Photos ─────────────────────────────────────────────────────────────
# Google OAuth credentials (from Google Cloud Console — Desktop app type)
GPHOTO_CLIENT_ID=your_client_id.apps.googleusercontent.com
GPHOTO_CLIENT_SECRET=your_client_secret_here

# Path inside the container where the OAuth token JSON is persisted.
# This file must survive container restarts — /data is a bind-mounted volume.
GPHOTO_TOKEN_PATH=/data/token.json

# Port published during the one-time OAuth setup run (docker run -p 8080:8080).
# Must match the Authorized Redirect URI registered in Google Cloud Console.
OAUTH_REDIRECT_PORT=8080

# ── Sync Behavior ─────────────────────────────────────────────────────────────
# Seconds between incremental sync checks (default: 5 minutes)
SYNC_INTERVAL_SECONDS=300

# Seconds between forced full syncs, which check for Google-side membership
# drift even when Immich reports no changes (default: 1 hour)
SYNC_FULL_INTERVAL_SECONDS=3600

# Maximum concurrent downloads from Immich
SYNC_DOWNLOAD_WORKERS=4

# ── Cache ─────────────────────────────────────────────────────────────────────
# Ephemeral cache directory. Backed by tmpfs in docker-compose — RAM only.
CACHE_DIR=/tmp/sync_cache

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
